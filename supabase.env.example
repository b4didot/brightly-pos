# Server-side Supabase values for Edge Functions or backend jobs.
# Do not expose these in the Vite frontend.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Production app URLs for allowed redirects, email links, and QR/device setup
# links generated by server-side code.
SITE_URL=https://www.brightlyph.com
DASHBOARD_URL=https://www.brightlyph.com/dashboard
DEVICE_SETUP_URL=https://www.brightlyph.com/device/setup
POS_URL=https://www.brightlyph.com/pos

# Optional local migration/admin values.
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL=
