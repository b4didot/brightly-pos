# Frontend-safe Supabase values.
# These are exposed to the browser by Vite, so only use the public project URL
# and anon/publishable key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Public app URLs used for QR links, redirects, and PWA install flows.
VITE_APP_ORIGIN=https://www.brightlyph.com
VITE_APP_DASHBOARD_PATH=/dashboard
VITE_APP_DEVICE_SETUP_PATH=/device/setup
VITE_APP_POS_PATH=/pos

# Optional backend API base URL. Use this only if a separate API server is
# introduced. Leave blank when using Supabase client + Edge Functions.
VITE_BRIGHTLY_API_URL=

# Optional Supabase Edge Function base URL. Defaults can be derived from
# VITE_SUPABASE_URL, but an explicit value is useful for staging.
VITE_SUPABASE_FUNCTIONS_URL=
